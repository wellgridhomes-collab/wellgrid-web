---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.fecha).valueOf() - new Date(a.data.fecha).valueOf()
);

const categorias = ['Todos', 'automatizacion', 'tecnologia', 'propiedades', 'lifestyle'];
const categoriasLabel: Record<string, string> = {
  'Todos': 'Todos',
  'automatizacion': 'Automatización',
  'tecnologia': 'Tecnología',
  'propiedades': 'Propiedades',
  'lifestyle': 'Lifestyle',
};
---

<Layout
  title="Blog — WellGrid Homes"
  description="Perspectivas, tendencias y conocimiento sobre automatización del hogar, tecnología residencial y vida de lujo."
>
  <section class="blog-hero">
    <div class="container">
      <span class="section-label">Blog</span>
      <h1>Perspectivas<br><em>& tendencias</em></h1>
      <p>Conocimiento sobre automatización, tecnología residencial y la nueva forma de vivir.</p>
    </div>
  </section>

  <section class="blog-content">
    <div class="container">
      {posts.length === 0 ? (
        <div class="empty-state">
          <div class="empty-deco"></div>
          <h2>Próximamente</h2>
          <p>El equipo WellGrid está preparando contenido exclusivo.<br>Vuelva pronto.</p>
          <a href="/contacto" class="btn-primary" style="margin-top: 2rem;">
            Contactar al equipo
          </a>
        </div>
      ) : (
        <div class="posts-grid">
          {posts.map((post, i) => (
            <a href={`/blog/${post.slug}`} class={`post-card ${i === 0 ? 'post-card--featured' : ''}`}>
              {post.data.imagen && (
                <div class="post-image">
                  <img src={post.data.imagen} alt={post.data.title} loading="lazy" />
                </div>
              )}
              <div class="post-body">
                <div class="post-meta">
                  <span class="post-categoria">
                    {categoriasLabel[post.data.categoria] || post.data.categoria}
                  </span>
                  <span class="post-fecha">
                    {new Date(post.data.fecha).toLocaleDateString('es-CL', {
                      year: 'numeric', month: 'long', day: 'numeric'
                    })}
                  </span>
                </div>
                <h2 class="post-titulo">{post.data.title}</h2>
                <p class="post-desc">{post.data.descripcion}</p>
                <span class="post-link">Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .blog-hero {
    padding: 10rem 0 5rem;
    border-bottom: 1px solid rgba(201, 169, 110, 0.1);
  }

  .blog-hero h1 {
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 300;
    color: var(--blanco);
    margin: 0.75rem 0 1.25rem;
    line-height: 1.05;
  }

  .blog-hero h1 em {
    font-style: italic;
    color: var(--dorado);
  }

  .blog-hero p {
    font-size: 1rem;
    color: var(--gris-claro);
    max-width: 480px;
    line-height: 1.75;
  }

  .blog-content {
    padding: 5rem 0 8rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: rgba(201, 169, 110, 0.06);
    border: 1px solid rgba(201, 169, 110, 0.06);
  }

  .post-card--featured {
    grid-column: span 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .post-card {
    background: var(--negro-2);
    display: flex;
    flex-direction: column;
    transition: background 0.3s ease;
  }

  .post-card:hover {
    background: var(--negro-3);
  }

  .post-image {
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .post-card--featured .post-image {
    aspect-ratio: unset;
    height: 100%;
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .post-card:hover .post-image img {
    transform: scale(1.03);
  }

  .post-body {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .post-categoria {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dorado);
    border: 1px solid rgba(201, 169, 110, 0.3);
    padding: 0.25rem 0.75rem;
  }

  .post-fecha {
    font-size: 0.78rem;
    color: var(--gris);
  }

  .post-titulo {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--blanco);
    line-height: 1.25;
  }

  .post-card--featured .post-titulo {
    font-size: 2rem;
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--gris-claro);
    line-height: 1.75;
    flex: 1;
  }

  .post-link {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dorado);
    margin-top: auto;
  }

  /* EMPTY STATE */
  .empty-state {
    text-align: center;
    padding: 6rem 0;
    max-width: 480px;
    margin: 0 auto;
  }

  .empty-deco {
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, transparent, var(--dorado));
    margin: 0 auto 3rem;
  }

  .empty-state h2 {
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--blanco);
    margin-bottom: 1rem;
  }

  .empty-state p {
    font-size: 0.95rem;
    color: var(--gris-claro);
    line-height: 1.75;
  }

  @media (max-width: 1000px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .post-card--featured {
      grid-column: span 2;
    }
  }

  @media (max-width: 640px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
    .post-card--featured {
      grid-column: span 1;
      grid-template-columns: 1fr;
    }
  }
</style>
