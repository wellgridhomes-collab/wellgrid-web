---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-gradient"></div>
      <div class="hero-grid"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-eyebrow">
        <span class="gold-line"></span>
        <span>Propiedades · Tecnología · Automatización</span>
      </div>
      <h1 class="hero-title">
        El hogar como<br>
        <em>obra maestra</em>
      </h1>
      <p class="hero-subtitle">
        WellGrid integra tecnología de vanguardia y automatización inteligente<br>
        para transformar propiedades en experiencias de vida excepcionales.
      </p>
      <div class="hero-actions">
        <a href="/servicios" class="btn-primary">
          Explorar servicios
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/contacto" class="btn-secondary">Agendar consulta</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">+120</span>
          <span class="stat-label">Propiedades integradas</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">8+</span>
          <span class="stat-label">Años de experiencia</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">98%</span>
          <span class="stat-label">Satisfacción de clientes</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll-indicator">
      <span>Descubrir</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- PROPUESTA DE VALOR -->
  <section class="about-strip">
    <div class="container">
      <p class="about-strip-text">
        <em>WellGrid</em> nació de la convicción de que un hogar excepcional no es solo arquitectura —
        es la intersección perfecta entre diseño, tecnología e intención de vida.
      </p>
    </div>
  </section>

  <!-- SERVICIOS PREVIEW -->
  <section class="services-preview">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Lo que hacemos</span>
        <h2 class="section-title">Servicios diseñados<br>para elevar su vida</h2>
      </div>
      <div class="services-grid">
        <a href="/servicios#automatizacion" class="service-card">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="1"/>
              <path d="M14 8v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="14" cy="14" r="2" fill="currentColor"/>
            </svg>
          </div>
          <h3>Automatización del hogar</h3>
          <p>Control total de iluminación, climatización, seguridad y entretenimiento desde un solo punto.</p>
          <span class="service-link">Conocer más →</span>
        </a>
        <a href="/servicios#tecnologia" class="service-card service-card--featured">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <rect x="4" y="6" width="20" height="14" rx="1" stroke="currentColor" stroke-width="1"/>
              <path d="M10 24h8M14 20v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="14" cy="13" r="3" stroke="currentColor" stroke-width="1"/>
            </svg>
          </div>
          <h3>Integración tecnológica</h3>
          <p>Sistemas de última generación seamlessly integrados en la arquitectura de su propiedad.</p>
          <span class="service-link">Conocer más →</span>
          <div class="featured-badge">Premium</div>
        </a>
        <a href="/servicios#consultoria" class="service-card">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <path d="M5 22L9 18M9 18C10.5 19.5 12.6 20.5 15 20.5C19.7 20.5 23.5 16.7 23.5 12C23.5 7.3 19.7 3.5 15 3.5C10.3 3.5 6.5 7.3 6.5 12C6.5 14.2 7.4 16.2 8.8 17.6L9 18Z" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
              <path d="M15 8v4l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Consultoría de propiedades</h3>
          <p>Asesoría especializada para identificar, evaluar y optimizar propiedades de alto valor.</p>
          <span class="service-link">Conocer más →</span>
        </a>
        <a href="/servicios#diseno" class="service-card">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <path d="M6 22L22 6M14 6h8v8" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="9" cy="19" r="4" stroke="currentColor" stroke-width="1"/>
            </svg>
          </div>
          <h3>Diseño de interiores smart</h3>
          <p>Espacios que fusionan estética premium con funcionalidad tecnológica de forma invisible.</p>
          <span class="service-link">Conocer más →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- FILOSOFÍA -->
  <section class="philosophy">
    <div class="container">
      <div class="philosophy-inner">
        <div class="philosophy-text">
          <span class="section-label">Nuestra filosofía</span>
          <h2>La tecnología al<br>servicio de la vida</h2>
          <p>
            No instalamos dispositivos. Creamos ecosistemas inteligentes que aprenden
            de sus hábitos, anticipan sus necesidades y elevan cada momento
            de su vida en el hogar.
          </p>
          <p>
            Cada propiedad que tocamos es tratada como un proyecto único.
            La combinación de arquitectura, tecnología y experiencia humana
            es lo que define el estándar WellGrid.
          </p>
          <a href="/servicios" class="btn-primary" style="margin-top: 2rem;">
            Nuestros servicios
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="philosophy-visual">
          <div class="philosophy-card philosophy-card--1">
            <span class="pc-number">01</span>
            <span class="pc-label">Diagnóstico integral</span>
          </div>
          <div class="philosophy-card philosophy-card--2">
            <span class="pc-number">02</span>
            <span class="pc-label">Diseño a medida</span>
          </div>
          <div class="philosophy-card philosophy-card--3">
            <span class="pc-number">03</span>
            <span class="pc-label">Integración experta</span>
          </div>
          <div class="philosophy-card philosophy-card--4">
            <span class="pc-number">04</span>
            <span class="pc-label">Soporte continuo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-deco"></div>
        <span class="section-label" style="justify-content: center; margin-bottom: 1.5rem;">Comencemos</span>
        <h2>¿Listo para elevar<br>su propiedad?</h2>
        <p>Hablemos sobre cómo WellGrid puede transformar su espacio en algo verdaderamente extraordinario.</p>
        <div class="cta-actions">
          <a href="/contacto" class="btn-primary">
            Agendar consulta gratuita
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/blog" class="btn-secondary">Leer el blog</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding-top: 80px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 60% 40%, rgba(201, 169, 110, 0.06) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 20% 80%, rgba(201, 169, 110, 0.04) 0%, transparent 60%),
      linear-gradient(180deg, var(--negro) 0%, var(--negro-2) 100%);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(201, 169, 110, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201, 169, 110, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse at center, rgba(0,0,0,0.6) 0%, transparent 75%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 5rem 2rem;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dorado);
    margin-bottom: 2rem;
  }

  .hero-title {
    font-size: clamp(3.5rem, 7vw, 6.5rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--blanco);
    margin-bottom: 1.75rem;
  }

  .hero-title em {
    font-style: italic;
    color: var(--dorado);
  }

  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--gris-claro);
    line-height: 1.75;
    max-width: 580px;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 4rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    color: var(--dorado);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--gris-claro);
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.1);
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    right: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    z-index: 1;
  }

  .hero-scroll-indicator span {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gris);
    writing-mode: vertical-rl;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--dorado), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* ABOUT STRIP */
  .about-strip {
    padding: 5rem 0;
    border-top: 1px solid rgba(201, 169, 110, 0.1);
    border-bottom: 1px solid rgba(201, 169, 110, 0.1);
    background: var(--negro-2);
  }

  .about-strip-text {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.5vw, 1.9rem);
    font-weight: 300;
    line-height: 1.5;
    color: var(--blanco-2);
    text-align: center;
    max-width: 780px;
    margin: 0 auto;
  }

  .about-strip-text em {
    font-style: italic;
    color: var(--dorado);
  }

  /* SERVICIOS PREVIEW */
  .services-preview {
    padding: var(--section-padding);
  }

  .section-header {
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 300;
    color: var(--blanco);
    margin-top: 0.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5px;
    background: rgba(201, 169, 110, 0.08);
    border: 1px solid rgba(201, 169, 110, 0.08);
  }

  .service-card {
    background: var(--negro-2);
    padding: 3rem;
    transition: background 0.3s ease;
    position: relative;
    display: block;
  }

  .service-card:hover {
    background: var(--negro-3);
  }

  .service-card--featured {
    background: var(--negro-3);
  }

  .service-icon {
    color: var(--dorado);
    margin-bottom: 1.5rem;
  }

  .service-card h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--blanco);
    margin-bottom: 0.875rem;
  }

  .service-card p {
    font-size: 0.9rem;
    color: var(--gris-claro);
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .service-link {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dorado);
    transition: letter-spacing 0.3s ease;
  }

  .service-card:hover .service-link {
    letter-spacing: 0.18em;
  }

  .featured-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--dorado);
    border: 1px solid rgba(201, 169, 110, 0.3);
    padding: 0.3rem 0.75rem;
  }

  /* FILOSOFÍA */
  .philosophy {
    padding: var(--section-padding);
    background: var(--negro-2);
    border-top: 1px solid rgba(201, 169, 110, 0.08);
    border-bottom: 1px solid rgba(201, 169, 110, 0.08);
  }

  .philosophy-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .philosophy-text h2 {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300;
    color: var(--blanco);
    margin-bottom: 1.5rem;
    margin-top: 0.5rem;
  }

  .philosophy-text p {
    font-size: 0.95rem;
    color: var(--gris-claro);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .philosophy-visual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5px;
    background: rgba(201, 169, 110, 0.08);
    border: 1px solid rgba(201, 169, 110, 0.08);
  }

  .philosophy-card {
    background: var(--negro-3);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: background 0.3s ease;
  }

  .philosophy-card:hover {
    background: var(--negro-4);
  }

  .pc-number {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 300;
    color: rgba(201, 169, 110, 0.3);
    line-height: 1;
  }

  .pc-label {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--blanco-2);
    letter-spacing: 0.04em;
  }

  /* CTA */
  .cta-section {
    padding: var(--section-padding);
    text-align: center;
  }

  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
  }

  .cta-deco {
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, transparent, var(--dorado));
    margin: 0 auto 3rem;
  }

  .cta-inner h2 {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 300;
    color: var(--blanco);
    margin-bottom: 1.25rem;
  }

  .cta-inner p {
    font-size: 0.95rem;
    color: var(--gris-claro);
    margin-bottom: 2.5rem;
    line-height: 1.75;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .philosophy-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .services-grid {
      grid-template-columns: 1fr;
    }
    .hero-stats {
      gap: 1.5rem;
    }
    .hero-scroll-indicator {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .hero-stats {
      flex-wrap: wrap;
    }
    .stat-divider { display: none; }
    .philosophy-visual {
      grid-template-columns: 1fr;
    }
    .service-card {
      padding: 2rem;
    }
  }
</style>
