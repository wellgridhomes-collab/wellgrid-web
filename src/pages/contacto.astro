---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacto — WellGrid Homes"
  description="Hablemos sobre su propiedad. Agenda una consulta gratuita con el equipo WellGrid."
>
  <section class="contact-hero">
    <div class="container">
      <div class="contact-grid">
        <!-- INFO -->
        <div class="contact-info">
          <span class="section-label">Contacto</span>
          <h1>Comencemos<br>una conversación</h1>
          <p>
            Cada transformación extraordinaria comienza con una conversación.
            Cuéntenos sobre su propiedad y sus objetivos — sin compromiso.
          </p>

          <div class="contact-details">
            <div class="contact-item">
              <span class="contact-item-label">Email</span>
              <a href="mailto:hola@wellgridhomes.com" class="contact-item-value">
                hola@wellgridhomes.com
              </a>
            </div>
            <div class="contact-item">
              <span class="contact-item-label">Teléfono</span>
              <a href="tel:+56912345678" class="contact-item-value">
                +56 9 1234 5678
              </a>
            </div>
            <div class="contact-item">
              <span class="contact-item-label">Ubicación</span>
              <span class="contact-item-value">Santiago, Chile</span>
            </div>
          </div>

          <div class="contact-horario">
            <span class="section-label" style="margin-bottom: 0.75rem;">Horario de atención</span>
            <p>Lunes a viernes, 9:00 — 18:00 hrs</p>
          </div>
        </div>

        <!-- FORM -->
        <div class="contact-form-wrap">
          <form class="contact-form" id="contactForm">
            <div class="form-row">
              <div class="form-group">
                <label for="nombre">Nombre</label>
                <input type="text" id="nombre" name="nombre" placeholder="Su nombre completo" required />
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="su@email.com" required />
              </div>
            </div>

            <div class="form-group">
              <label for="telefono">Teléfono (opcional)</label>
              <input type="tel" id="telefono" name="telefono" placeholder="+56 9..." />
            </div>

            <div class="form-group">
              <label>Servicio de interés</label>
              <div class="form-options">
                {['Automatización del hogar', 'Integración tecnológica', 'Consultoría de propiedades', 'Diseño de interiores smart', 'Otro / Proyecto completo'].map(op => (
                  <label class="form-option">
                    <input type="checkbox" name="servicio" value={op} />
                    <span>{op}</span>
                  </label>
                ))}
              </div>
            </div>

            <div class="form-group">
              <label for="mensaje">Cuéntenos sobre su proyecto</label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="5"
                placeholder="Describa su propiedad, sus objetivos y cualquier detalle relevante..."
                required
              ></textarea>
            </div>

            <button type="submit" class="btn-primary form-submit">
              Enviar mensaje
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <div class="form-success" id="formSuccess">
              <div class="success-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M4 12l5 5L20 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>Mensaje enviado</h3>
              <p>Nos pondremos en contacto dentro de las próximas 24 horas.</p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const success = document.getElementById('formSuccess');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('.form-submit') as HTMLButtonElement;
    btn.textContent = 'Enviando...';
    btn.disabled = true;

    // Simular envío (aquí conectar con backend real o Formspree)
    await new Promise(r => setTimeout(r, 1200));

    form.style.opacity = '0';
    form.style.transform = 'translateY(-16px)';
    setTimeout(() => {
      form.style.display = 'none';
      if (success) {
        success.style.display = 'flex';
        setTimeout(() => success.style.opacity = '1', 50);
      }
    }, 300);
  });
</script>

<style>
  .contact-hero {
    padding: 10rem 0 6rem;
    min-height: 100vh;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 6rem;
    align-items: start;
  }

  .contact-info h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    color: var(--blanco);
    margin: 0.75rem 0 1.5rem;
    line-height: 1.1;
  }

  .contact-info > p {
    font-size: 0.95rem;
    color: var(--gris-claro);
    line-height: 1.8;
    margin-bottom: 3rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .contact-item-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dorado);
  }

  .contact-item-value {
    font-size: 1rem;
    color: var(--blanco-2);
    transition: color 0.25s ease;
  }

  a.contact-item-value:hover {
    color: var(--dorado);
  }

  .contact-horario p {
    font-size: 0.9rem;
    color: var(--gris-claro);
  }

  /* FORM */
  .contact-form-wrap {
    background: var(--negro-2);
    border: 1px solid rgba(201, 169, 110, 0.1);
    padding: 3rem;
  }

  .contact-form {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gris-claro);
  }

  .form-group input,
  .form-group textarea {
    background: var(--negro-3);
    border: 1px solid rgba(255,255,255,0.08);
    color: var(--blanco);
    padding: 0.875rem 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 300;
    transition: border-color 0.25s ease;
    outline: none;
    resize: vertical;
    width: 100%;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--gris);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: rgba(201, 169, 110, 0.5);
  }

  .form-options {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .form-option {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    cursor: pointer;
    font-size: 0.9rem;
    color: var(--gris-claro);
    transition: color 0.2s ease;
    text-transform: none;
    letter-spacing: normal;
    font-weight: 300;
  }

  .form-option:hover {
    color: var(--blanco);
  }

  .form-option input[type="checkbox"] {
    width: 16px;
    height: 16px;
    border: 1px solid rgba(201, 169, 110, 0.4);
    background: transparent;
    appearance: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    position: relative;
    transition: all 0.2s ease;
  }

  .form-option input[type="checkbox"]:checked {
    background: var(--dorado);
    border-color: var(--dorado);
  }

  .form-option input[type="checkbox"]:checked::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--negro);
    mask-image: url("data:image/svg+xml,%3Csvg width='10' height='10' viewBox='0 0 10 10' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 5l2.5 2.5L8 3' stroke='white' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
    mask-repeat: no-repeat;
    mask-position: center;
  }

  .form-submit {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .form-success {
    display: none;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    opacity: 0;
    transition: opacity 0.4s ease;
    padding: 3rem 0;
  }

  .success-icon {
    width: 56px;
    height: 56px;
    border: 1px solid var(--dorado);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--dorado);
  }

  .form-success h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 300;
    color: var(--blanco);
  }

  .form-success p {
    font-size: 0.9rem;
    color: var(--gris-claro);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 560px) {
    .form-row {
      grid-template-columns: 1fr;
    }
    .contact-form-wrap {
      padding: 2rem 1.5rem;
    }
  }
</style>
