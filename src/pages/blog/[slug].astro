---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const categoriasLabel: Record<string, string> = {
  'automatizacion': 'Automatización',
  'tecnologia': 'Tecnología',
  'propiedades': 'Propiedades',
  'lifestyle': 'Lifestyle',
};
---

<Layout
  title={`${post.data.title} — WellGrid Homes`}
  description={post.data.descripcion}
  image={post.data.imagen}
>
  <article class="post-article">
    <div class="post-header">
      <div class="container">
        <a href="/blog" class="back-link">← Volver al blog</a>
        <div class="post-meta">
          <span class="post-categoria">
            {categoriasLabel[post.data.categoria] || post.data.categoria}
          </span>
          <span class="post-fecha">
            {new Date(post.data.fecha).toLocaleDateString('es-CL', {
              year: 'numeric', month: 'long', day: 'numeric'
            })}
          </span>
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-lead">{post.data.descripcion}</p>
      </div>
    </div>

    {post.data.imagen && (
      <div class="post-hero-image">
        <div class="container">
          <img src={post.data.imagen} alt={post.data.title} />
        </div>
      </div>
    )}

    <div class="post-body">
      <div class="container">
        <div class="post-content">
          <Content />
        </div>
        <aside class="post-sidebar">
          <div class="sidebar-sticky">
            <div class="sidebar-block">
              <h3>¿Le interesa este tema?</h3>
              <p>Hablemos sobre cómo aplicar estas soluciones en su propiedad.</p>
              <a href="/contacto" class="btn-primary" style="margin-top: 1.25rem; width: 100%; justify-content: center;">
                Agendar consulta
              </a>
            </div>
            <div class="sidebar-block">
              <a href="/blog" class="sidebar-back">← Todos los artículos</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
  .post-header {
    padding: 9rem 0 4rem;
    border-bottom: 1px solid rgba(201, 169, 110, 0.08);
  }

  .back-link {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gris);
    display: inline-block;
    margin-bottom: 2rem;
    transition: color 0.25s ease;
  }

  .back-link:hover {
    color: var(--dorado);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .post-categoria {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dorado);
    border: 1px solid rgba(201, 169, 110, 0.3);
    padding: 0.25rem 0.75rem;
  }

  .post-fecha {
    font-size: 0.78rem;
    color: var(--gris);
  }

  .post-header h1 {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 300;
    color: var(--blanco);
    margin-bottom: 1.25rem;
    max-width: 800px;
    line-height: 1.1;
  }

  .post-lead {
    font-size: 1.1rem;
    color: var(--gris-claro);
    max-width: 640px;
    line-height: 1.75;
    font-style: italic;
    font-family: var(--font-display);
    font-weight: 300;
  }

  .post-hero-image {
    padding: 3rem 0;
    background: var(--negro-2);
  }

  .post-hero-image img {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
  }

  .post-body {
    padding: 5rem 0 8rem;
  }

  .post-body .container {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 6rem;
    align-items: start;
  }

  .post-content {
    color: var(--blanco-2);
    font-size: 1rem;
    line-height: 1.9;
  }

  .post-content h2 {
    font-size: 1.9rem;
    font-weight: 300;
    color: var(--blanco);
    margin: 3rem 0 1.25rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(201, 169, 110, 0.1);
  }

  .post-content h3 {
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--blanco);
    margin: 2rem 0 0.875rem;
  }

  .post-content p {
    margin-bottom: 1.5rem;
    color: var(--gris-claro);
  }

  .post-content ul, .post-content ol {
    margin: 1.25rem 0 1.5rem 1.5rem;
    color: var(--gris-claro);
  }

  .post-content li {
    margin-bottom: 0.5rem;
  }

  .post-content strong {
    color: var(--blanco);
    font-weight: 500;
  }

  .post-content em {
    color: var(--dorado);
    font-style: italic;
  }

  .post-content blockquote {
    border-left: 2px solid var(--dorado);
    padding: 1.25rem 1.5rem;
    margin: 2rem 0;
    background: var(--negro-2);
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-style: italic;
    color: var(--blanco-2);
  }

  /* Sidebar */
  .sidebar-sticky {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-block {
    background: var(--negro-2);
    border: 1px solid rgba(201, 169, 110, 0.1);
    padding: 1.75rem;
  }

  .sidebar-block h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--blanco);
    margin-bottom: 0.75rem;
  }

  .sidebar-block p {
    font-size: 0.875rem;
    color: var(--gris-claro);
    line-height: 1.7;
  }

  .sidebar-back {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gris);
    transition: color 0.25s ease;
    display: block;
  }

  .sidebar-back:hover {
    color: var(--dorado);
  }

  @media (max-width: 900px) {
    .post-body .container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .sidebar-sticky {
      position: static;
    }
  }
</style>
