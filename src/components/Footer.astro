---
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="logo">
          <span class="logo-main">WellGrid</span>
          <span class="logo-sub">Homes</span>
        </div>
        <p class="footer-tagline">
          Integramos tecnología, automatización<br>y diseño para elevar su forma de vivir.
        </p>
      </div>

      <div class="footer-links">
        <div class="footer-col">
          <h4>Navegación</h4>
          <a href="/">Inicio</a>
          <a href="/servicios">Servicios</a>
          <a href="/blog">Blog</a>
          <a href="/contacto">Contacto</a>
        </div>
        <div class="footer-col">
          <h4>Servicios</h4>
          <a href="/servicios#automatizacion">Automatización del hogar</a>
          <a href="/servicios#tecnologia">Integración tecnológica</a>
          <a href="/servicios#consultoria">Consultoría de propiedades</a>
          <a href="/servicios#diseno">Diseño de interiores smart</a>
        </div>
        <div class="footer-col">
          <h4>Contacto</h4>
          <a href="mailto:hola@wellgridhomes.com">hola@wellgridhomes.com</a>
          <a href="tel:+56912345678">+56 9 1234 5678</a>
          <p style="color: var(--gris); font-size: 0.85rem; margin-top: 0.5rem;">Santiago, Chile</p>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} WellGrid Homes. Todos los derechos reservados.</p>
      <div class="footer-divider"></div>
      <p class="footer-craft">Vivir con intención.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--negro-2);
    border-top: 1px solid rgba(201, 169, 110, 0.12);
    padding: 5rem 0 2.5rem;
    margin-top: auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 2rem;
  }

  .logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .logo-main {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--blanco);
    letter-spacing: 0.03em;
  }

  .logo-sub {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--dorado);
    margin-top: 2px;
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--gris-claro);
    line-height: 1.7;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-col h4 {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dorado);
    margin-bottom: 1.25rem;
  }

  .footer-col a {
    display: block;
    font-size: 0.875rem;
    color: var(--gris-claro);
    margin-bottom: 0.65rem;
    transition: color 0.25s ease;
  }

  .footer-col a:hover {
    color: var(--blanco);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-bottom p {
    font-size: 0.78rem;
    color: var(--gris);
    letter-spacing: 0.04em;
  }

  .footer-divider {
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.06);
  }

  .footer-craft {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem !important;
    color: var(--dorado) !important;
    letter-spacing: 0.02em !important;
  }

  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .footer-links {
      grid-template-columns: 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .footer-divider { display: none; }
  }
</style>
